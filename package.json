{
  "name": "trend-watcher-backend",
  "version": "1.0.0",
  "description": "Mac Mini backend for Trend Watcher — TikTok trend intelligence platform for Epilog Creative",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "scrape": "node -e \"require('./src/scrapers/tiktok.js').scrapeOnce()\"",
    "test": "jest",
    "tunnel": "cloudflared tunnel run trend-watcher",
    "start:prod": "pm2 start ecosystem.config.js --env production",
    "stop:prod": "pm2 stop trend-watcher",
    "logs:prod": "pm2 logs trend-watcher"
  },
  "keywords": [
    "tiktok",
    "trends",
    "scraper",
    "supabase"
  ],
  "author": "Epilog Creative",
  "license": "PRIVATE",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "playwright": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.14"
  }
}
